#!/usr/bin/env bash
set -euo pipefail

use_gh() {
  local user=$1 output

  mkdir -p "$HOME/.local/state/gh"
  if ! output=$(gh auth switch --user "$user" 2>&1); then
    echo "failed to switch account ${user}: ${output}" >&2
    return 1
  fi
  echo "$output" | awk '{print $NF}' > "$HOME/.local/state/gh/active-user"
}
