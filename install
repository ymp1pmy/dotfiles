#!/bin/sh
set -e
DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure aqua can find its config before symlinks are applied.
# If ~/.config doesn't exist, symlink the whole dir.
# If ~/.config is already a real directory (e.g. Codespaces), symlink just aquaproj-aqua.
if [ ! -e "$HOME/.config" ]; then
    ln -s "$DIR/files/.config" "$HOME/.config"
elif [ ! -e "$HOME/.config/aquaproj-aqua" ]; then
    ln -s "$DIR/files/.config/aquaproj-aqua" "$HOME/.config/aquaproj-aqua" 2>/dev/null \
        || export AQUA_CONFIG="$DIR/files/.config/aquaproj-aqua/aqua.yaml"
fi

# 1. Install aqua and all registered tools (including Go)
"$DIR/.bin/install-aqua.sh"

# 2. Make aqua-managed tools available for this session
AQUA_BIN="$HOME/.local/share/aquaproj-aqua/bin"
export PATH="$AQUA_BIN:$PATH"

# install-aqua.sh exports AQUA_CONFIG internally, but child-process env vars don't
# propagate back to the parent shell. Re-apply the same default here so that
# aqua-proxy ($AQUA_BIN/go) can resolve the go definition when called below.
AQUA_CONFIG=${AQUA_CONFIG:-$HOME/.config/aquaproj-aqua/aqua.yaml}
export AQUA_CONFIG

# 3. Apply dotfiles
# Use the actual Go binary via GOROOT to avoid aqua-proxy issues in sh context
# (GOROOT single-arg lookup works via proxy; full go run does not in sh scripts)
GOROOT=$("$AQUA_BIN/go" env GOROOT 2>/dev/null)
GO_BIN="${GOROOT:+$GOROOT/bin/go}"
GO_BIN="${GO_BIN:-go}"
cd "$DIR/installer"
"$GO_BIN" run . -c "$DIR/install.conf.yaml"
