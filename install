#!/bin/sh
set -e
DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure aqua can find its config before symlinks are applied.
# 1. ~/.config doesn't exist → symlink the whole dir
# 2. ~/.config is a real dir → try to symlink just aquaproj-aqua
# 3. That also fails (permission denied) → fall back to AQUA_CONFIG env override
if [ ! -e "$HOME/.config" ]; then
    ln -s "$DIR/files/.config" "$HOME/.config"
elif [ ! -e "$HOME/.config/aquaproj-aqua" ]; then
    ln -s "$DIR/files/.config/aquaproj-aqua" "$HOME/.config/aquaproj-aqua" 2>/dev/null \
        || export AQUA_CONFIG="$DIR/files/.config/aquaproj-aqua"
fi

# 1. Install aqua and all registered tools (including Go)
"$DIR/.bin/install-aqua.sh"

# 2. Make aqua-managed tools available for this session
export PATH="$HOME/.local/share/aquaproj-aqua/bin:$PATH"

# 3. Apply dotfiles
cd "$DIR"
go run ./installer
